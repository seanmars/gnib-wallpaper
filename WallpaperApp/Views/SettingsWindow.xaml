<Window x:Class="WallpaperApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WallpaperApp.ViewModels"
        Title="Settings"
        Width="560"
        Height="420"
        MinWidth="480"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#1E1E1E"
        Foreground="#EEEEEE">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Default country"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1"
                   Text="The selected country is loaded on startup. Applies on next startup."
                   Foreground="#AAAAAA"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="3"
                BorderBrush="#333333"
                BorderThickness="1"
                Background="#161616"
                CornerRadius="4"
                Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Countries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SettingsCountryItem}">
                            <Button Command="{Binding DataContext.SelectDefaultCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="2"
                                    Cursor="Hand"
                                    FocusVisualStyle="{x:Null}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="10,8">
                                            <ContentPresenter HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1F3A5F"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0"
                                          Width="36" Height="24"
                                          Margin="0,0,12,0">
                                        <Image Source="{Binding FlagImage}"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Visibility="{Binding FlagImage, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding Code}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#DDDDDD"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Visibility="{Binding FlagImage, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                                    </Grid>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               Foreground="#EEEEEE"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Column="2"
                                               Text="✓"
                                               Foreground="#3A9AFF"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Margin="8,0,4,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
