<Window x:Class="WallpaperApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WallpaperApp"
        xmlns:vm="clr-namespace:WallpaperApp.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="720" Width="1280"
        MinHeight="400" MinWidth="600"
        Background="#101010">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel LastChildFill="True">

        <Border DockPanel.Dock="Top"
                Background="#1E1E1E"
                BorderBrush="#333333"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Countries}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CountryItem}">
                            <Border Margin="4,2"
                                    CornerRadius="6"
                                    BorderThickness="2"
                                    Padding="0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="#3A9AFF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Button Command="{Binding DataContext.SelectCountryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{Binding Name}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="6,4"
                                        Cursor="Hand"
                                        Focusable="False"
                                        FocusVisualStyle="{x:Null}"
                                        SnapsToDevicePixels="True">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Grid Width="44" Height="30" CacheMode="BitmapCache">
                                        <Image Source="{Binding FlagImage}"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Visibility="{Binding FlagImage, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding Code}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#DDDDDD"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Visibility="{Binding FlagImage, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                                    </Grid>
                                </Button>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Background="#101010">

            <Image Source="{Binding CurrentImage}"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Visibility="{Binding CurrentImage, Converter={StaticResource NullToVisibilityConverter}}"/>

            <Border VerticalAlignment="Bottom"
                    Background="#80000000"
                    Padding="12,6"
                    Visibility="{Binding CurrentWallpaper, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding CurrentWallpaper.Title}"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding CurrentWallpaper.Copyright}"
                               Foreground="#CCCCCC"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <Grid Visibility="{Binding State, Converter={StaticResource LoadStateToVisibilityConverter}, ConverterParameter=Loading}">
                <Grid.Background>
                    <SolidColorBrush Color="Black" Opacity="0.35"/>
                </Grid.Background>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True"
                                 Width="240" Height="6"
                                 Foreground="#3A9AFF"
                                 Background="#33222222"
                                 BorderThickness="0"/>
                    <TextBlock Text="Loading wallpaper..."
                               Foreground="White"
                               FontSize="14"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Border Background="#101010"
                    Visibility="{Binding State, Converter={StaticResource LoadStateToVisibilityConverter}, ConverterParameter=Error}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#FF7878"
                           FontSize="14"
                           TextWrapping="Wrap"
                           MaxWidth="600"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
